#!/usr/bin/env php
<?php

declare(strict_types=1);

include $_composer_autoload_path ?? __DIR__ . '/../vendor/autoload.php';

use ScipPhp\Indexer;

$options = \getopt('h', ['help', 'memory-limit:', 'project-root:', 'output:']);
if ($options === false) {
    echo "Cannot parse options.\n";
    exit(1);
}

if (isset($options['h']) || isset($options['help'])) {
    echo "usage: {$argv[0]} [options]\n\n";
    echo "scip-php is a SCIP indexer for PHP\n\n";
    echo "Options:\n";
    echo "  -h --help                          display this help and exit\n";
    echo "     --memory-limit=\"1G\"             memory limit\n";
    echo "     --project-root=\"./path\"         project root directory (default: cwd)\n";
    echo "     --output=\"./index.scip\"         output file path (default: <project-root>/index.scip)\n";
    exit(0);
}

$memoryLimit = $options['memory-limit'] ?? '1G';
if (!\is_string($memoryLimit)) {
    echo "Invalid memory limit.\n";
    exit(1);
}

if (\ini_set('memory_limit', $memoryLimit) === false) {
    echo "Cannot set memory limit {$memoryLimit}.\n";
    exit(1);
}

$projectRoot = isset($options['project-root']) && \is_string($options['project-root'])
    ? \realpath($options['project-root'])
    : \getcwd();

if ($projectRoot === false || !\is_dir($projectRoot)) {
    echo "Invalid project root directory.\n";
    exit(1);
}

$outputPath = isset($options['output']) && \is_string($options['output'])
    ? $options['output']
    : $projectRoot . '/index.scip';

$version = '0.0.1';
$args = \array_splice($argv, 1);

$startTime = microtime(true);

$indexer = new Indexer($projectRoot, $version, $args);
$index = $indexer->index();

\file_put_contents(
    $outputPath,
    $index->serializeToString(),
);

$duration = round(microtime(true) - $startTime, 2);
$fileCount = count($index->getDocuments());
$extCount = count($index->getExternalSymbols());
echo "Done: {$fileCount} documents, {$extCount} external symbols, {$duration}s\n";
